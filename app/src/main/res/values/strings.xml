    <!-- Privacy Policy -->
    <string name="privacy_policy_intro">Cricket Festival Planner is committed to protecting your privacy. This policy explains how we handle your data.</string>
    <string name="privacy_policy_data_title">Data We Collect</string>
    <string name="privacy_policy_data_body">This app does not collect or transmit any personal data. All tournament information, match results, and team data you enter are stored exclusively on your device.</string>
    <string name="privacy_policy_storage_title">Local Storage</string>
    <string name="privacy_policy_storage_body">All data is stored locally using a Room database and Android DataStore. No data is sent to external servers. You can export or delete your data at any time from the Settings screen.</string>
