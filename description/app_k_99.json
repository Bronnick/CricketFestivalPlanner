        "screenName": "OnboardingScreen1",
        "view": "OnboardingView1",
        "viewModel": "OnboardingViewModel",
        "screenType": "Onboarding",
        "primaryPurpose": "Introduce app purpose and main features",
        "userActions": [
          "Next"
        ],
        "inputFields": [],
        "validationReference": "globalRules",
        "dataReadFrom": "local",
        "dataWriteTo": "none",
        "cachingPolicy": "none",
        "offlineBehavior": "full",
        "connectedServices": [],
        "navigationLinks": [
          "OnboardingScreen2"
