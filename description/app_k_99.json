{
  "project": {
    "name": "Cricket Festival Planner",
    "platform": [
      "Android"
    ],
    "language": "Kotlin",
    "minimumOSVersion": "8.0",
    "architecture": "MVVM",
    "dependencies": [
      "androidx.lifecycle",
      "Room",
      "Material Components",
      "Kotlin Coroutines"
    ],
    "version": "1.0"
  },
  "designSystem": {
    "theme": "Light",
    "colors": {
      "primaryBackground": "#F9FAFB",
      "secondaryBackground": "#FFFFFF",
      "primaryAccent": "#2176FF",
      "secondaryAccent": "#4B9BFF",
      "textPrimary": "#1A1A1A",
      "textSecondary": "#4A4A4A",
      "divider": "#E3E8EF",
      "success": "#31C48D",
      "error": "#F05252",
      "warning": "#FACC15",
      "info": "#3B82F6"
    },
    "typography": {
      "fontFamily": "Roboto",
      "headingWeight": 700,
      "bodyWeight": 400,
      "captionWeight": 400,
      "headingSize": 22,
      "bodySize": 16,
      "captionSize": 13
    },
    "spacing": {
      "xs": 4,
      "sm": 8,
      "md": 16,
      "lg": 24,
      "xl": 32
    },
    "radius": {
      "sm": 6,
      "md": 12,
      "lg": 20
    },
    "elevation": {
      "card": 2,
      "modal": 8,
      "fab": 12
    }
  },
  "app": {
    "entryPoint": "MainActivity.kt",
    "lifecycle": "SingleActivity",
    "preloader": {
      "screenName": "PreloaderScreen",
      "animationType": "CircularLoader",
      "initializationLogic": "App checks local storage, loads theme, verifies dependencies, and prepares user data.",
      "dependencyChecks": [
        "Room database",
        "Theme files",
        "User preferences"
      ],
      "themeLoading": "Loads Light theme and applies accent colors.",
      "transitionLogic": "On completion, navigates to OnboardingScreen or HomeScreen based on user status."
    },
    "navigation": {
      "type": "BottomTabNavigation",
      "structure": [
        {
          "tab": "Home",
          "destination": "HomeScreen"
        },
        {
          "tab": "Tournaments",
          "destination": "TournamentListScreen"
        },
        {
          "tab": "Analytics",
          "destination": "AnalyticsScreen"
        },
        {
          "tab": "Settings",
          "destination": "SettingsScreen"
        }
      ]
    },
    "features": [
