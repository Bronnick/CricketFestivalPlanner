        "viewModel": "CreateTournamentViewModel",
        "screenType": "Create/Edit",
        "primaryPurpose": "Create a new tournament with custom format",
        "userActions": [
          "Save",
          "Cancel"
        ],
        "inputFields": [
          {
            "fieldName": "tournamentName",
            "fieldType": "text",
            "required": true,
            "validationGroup": "textFieldRules",
            "defaultValue": "",
            "storageLocation": "local"
          },
          {
            "fieldName": "matchType",
            "fieldType": "selection",
            "required": true,
            "validationGroup": "selectionRules",
            "defaultValue": "T20",
            "storageLocation": "local"
          },
          {
            "fieldName": "teamCount",
            "fieldType": "numeric",
            "required": true,
            "validationGroup": "numericFieldRules",
            "defaultValue": 4,
            "storageLocation": "local"
          },
          {
            "fieldName": "pointSystem",
            "fieldType": "selection",
            "required": true,
            "validationGroup": "selectionRules",
            "defaultValue": "Standard",
            "storageLocation": "local"
          },
          {
            "fieldName": "structure",
            "fieldType": "selection",
            "required": true,
            "validationGroup": "selectionRules",
            "defaultValue": "Round Robin",
            "storageLocation": "local"
          },
          {
            "fieldName": "duration",
            "fieldType": "selection",
            "required": true,
            "validationGroup": "selectionRules",
            "defaultValue": "Weekend",
            "storageLocation": "local"
          },
          {
            "fieldName": "location",
            "fieldType": "text",
            "required": false,
            "validationGroup": "textFieldRules",
            "defaultValue": "",
            "storageLocation": "local"
          },
          {
            "fieldName": "posterImage",
            "fieldType": "image",
            "required": false,
            "validationGroup": "imageRules",
            "defaultValue": "",
            "storageLocation": "local"
          }
        ],
        "validationReference": "formSubmissionPolicy",
        "dataReadFrom": "local",
        "dataWriteTo": "local",
        "cachingPolicy": "persistent",
        "offlineBehavior": "full",
        "connectedServices": [],
        "navigationLinks": [
          "MatchScheduleScreen",
          "HomeScreen"
        ],
        "loadingState": "saving",
        "emptyState": "hidden",
        "errorState": "show error",
        "retryBehavior": "retry save"
      },
