    "services": [
      {
        "serviceName": "LocalDatabase",
        "serviceType": "Room",
        "persistence": "persistent",
        "sync": "manual",
        "scope": "app-wide"
      },
      {
        "serviceName": "ThemeManager",
        "serviceType": "local",
        "persistence": "session",
        "sync": "none",
        "scope": "user"
      },
      {
        "serviceName": "ExportImportService",
        "serviceType": "local",
        "persistence": "manual",
        "sync": "manual",
        "scope": "user"
      }
    ],
    "validation": {
      "globalRules": {
        "constraints": "All required fields must be filled; no empty submissions.",
        "errorMessage": "Please complete all required fields.",
        "systemBehavior": "Block submission and highlight errors."
      },
      "textFieldRules": {
        "constraints": "Max 40 chars; no special symbols except space and dash.",
        "errorMessage": "Text must be under 40 characters and contain only allowed symbols.",
        "systemBehavior": "Show inline error and block field."
      },
      "numericFieldRules": {
        "constraints": "Positive integers only; min 2, max 32.",
        "errorMessage": "Value must be a positive integer between 2 and 32.",
        "systemBehavior": "Show inline error and block field."
      },
      "dateFieldRules": {
        "constraints": "Valid date/time; not in the past.",
        "errorMessage": "Date/time must be valid and not in the past.",
        "systemBehavior": "Show inline error and block field."
      },
      "imageRules": {
        "constraints": "JPG/PNG only; max 2MB.",
        "errorMessage": "Image must be JPG or PNG and under 2MB.",
        "systemBehavior": "Show inline error and block field."
      },
      "selectionRules": {
        "constraints": "Selection required from predefined options.",
        "errorMessage": "Please select an option.",
        "systemBehavior": "Show inline error and block field."
      },
      "errorHandlingStrategy": {
        "constraints": "All errors logged; user notified for critical failures.",
        "errorMessage": "An error occurred. Please try again.",
        "systemBehavior": "Show dialog and allow retry."
      },
      "formSubmissionPolicy": {
        "constraints": "All validations must pass before submission.",
        "errorMessage": "Please correct errors before submitting.",
        "systemBehavior": "Block submission and scroll to first error."
      }
    },
    "components": [
      "Button",
      "TextField",
      "SelectionInput",
      "DatePicker",
      "ImagePicker",
      "Card",
      "TabBar",
      "BottomNavigation",
      "Loader",
      "Snackbar",
      "Dialog"
    ],
    "ratingFlow": {
      "implementation": "Native",
      "api": "In-App Review API",
      "threshold": 4,
      "feedbackForm": false,
      "validationRules": {
        "constraints": "Rating must be 1–5 stars.",
        "errorMessage": "Please select a rating.",
        "systemBehavior": "Block submission if not selected."
      },
      "redirectCondition": "If rating >= 4, prompt for Play Store review; else, show thank you."
    },
    "notificationFlows": [
      {
        "notificationType": "TournamentReminder",
        "title": "Upcoming Match",
        "body": "Your next cricket match is scheduled soon. Check the schedule for details.",
        "triggerCondition": "1 hour before match start",
        "frequency": "per match",
        "deepLinkDestination": "MatchScheduleScreen",
        "relatedFeature": "MatchSchedule"
      },
      {
        "notificationType": "ResultEntryReminder",
        "title": "Enter Match Result",
        "body": "Don't forget to enter the result for your recent match.",
        "triggerCondition": "30 minutes after match end",
        "frequency": "per match",
        "deepLinkDestination": "MatchResultScreen",
        "relatedFeature": "MatchResult"
      }
    ]
  }
}