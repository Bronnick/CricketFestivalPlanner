        "userActions": [
          "Next",
          "Back"
        ],
        "inputFields": [],
        "validationReference": "globalRules",
        "dataReadFrom": "local",
        "dataWriteTo": "none",
        "cachingPolicy": "none",
        "offlineBehavior": "full",
        "connectedServices": [],
        "navigationLinks": [
          "OnboardingScreen3",
          "OnboardingScreen1"
        ],
        "loadingState": "idle",
        "emptyState": "hidden",
        "errorState": "hidden",
        "retryBehavior": "none"
